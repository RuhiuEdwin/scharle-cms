{
  "kind": "singleType",
  "collectionName": "site_settings",
  "info": {
    "singularName": "site-setting",
    "pluralName": "site-settings",
    "displayName": "Site Settings"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "default": "Scharle Beauty College"
    },
    "tagline": {
      "type": "string",
      "default": "Learn It. Live It. Glow It."
    },
    "phone": {
      "type": "string"
    },
    "email": {
      "type": "email"
    },
    "address": {
      "type": "string",
      "default": "Outspan Plaza, Nyeri Town"
    },
    "socialLinks": {
      "type": "component",
      "repeatable": true,
      "component": "shared.social-link"
    },
    "calendlyUrl": {
      "type": "string"
    }
  }
}
