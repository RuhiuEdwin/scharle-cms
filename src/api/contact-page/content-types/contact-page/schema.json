{
  "kind": "singleType",
  "collectionName": "contact_page",
  "info": {
    "singularName": "contact-page",
    "pluralName": "contact-pages",
    "displayName": "Contact Page"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "phone": {
      "type": "string"
    },
    "email": {
      "type": "email"
    },
    "address": {
      "type": "string",
      "default": "Outspan Plaza, Nyeri Town"
    },
    "mapEmbedUrl": {
      "type": "string"
    },
    "socialLinks": {
      "type": "component",
      "repeatable": true,
      "component": "shared.social-link"
    },
    "seoTitle": {
      "type": "string"
    },
    "seoDescription": {
      "type": "text"
    }
  }
}
